{
  "name": "SHT30 датчик воздуха",
  "author": "Артём Бобков",
  "pins": ["VCC", "GND", "SCL", "SDA", "ADDR"],
  "controls": [
    {
      "id": "temperature",
      "label": "Температура (°C)",
      "type": "range",
      "min": -20,
      "max": 80,
      "step": 0.1,
      "value": 24
    },
    {
      "id": "humidity",
      "label": "Влажность (%)",
      "type": "range",
      "min": 0,
      "max": 100,
      "step": 1,
      "value": 60
    },
    {
      "id": "i2cAddress",
      "label": "I2C адрес, десятичный",
      "type": "range",
      "min": 68,
      "max": 69,
      "step": 1,
      "value": 68
    }
  ]
}
